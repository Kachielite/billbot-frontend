{
  "name": "billbot-frontend",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky",
    "prebuild": "expo prebuild --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "prebuild:android": "expo prebuild --platform android --clean"
  },
  "dependencies": {
    "@callstack/liquid-glass": "^0.7.1",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^8.0.0-alpha.22",
    "@react-navigation/elements": "^3.0.0-alpha.20",
    "@react-navigation/native": "^8.0.0-alpha.17",
    "@react-navigation/native-stack": "^8.0.0-alpha.24",
    "axios": "^1.15.0",
    "expo": "~55.0.17",
    "expo-apple-authentication": "^55.0.13",
    "expo-glass-effect": "^55.0.10",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.16",
    "lottie-react-native": "^7.3.6",
    "moment": "^2.30.1",
    "react": "19.2.0",
    "react-hook-form": "^7.72.1",
    "react-native": "0.83.6",
    "react-native-element-dropdown": "^2.12.4",
    "react-native-image-picker": "^8.2.1",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.4",
    "react-native-popover-view": "^6.1.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "0.7.4",
    "react-query": "^3.39.3",
    "rn-emoji-keyboard": "^1.7.0",
    "toastify-react-native": "^7.2.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": "prettier --write"
  },
  "private": true
}
