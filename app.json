{
  "expo": {
    "name": "billbot-frontend",
    "slug": "billbot-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/core/assets/icons/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./src/core/assets/icons/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "usesAppleSignIn": true,
      "supportsTablet": true,
      "bundleIdentifier": "com.kachielite.billbotfrontend",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "BillBot needs access to your photo library to attach receipts and payment proof.",
        "NSCameraUsageDescription": "BillBot needs camera access to capture receipts and payment proof.",
        "NSPhotoLibraryAddUsageDescription": "BillBot needs access to save images to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./src/core/assets/icons/android-icon-foreground.png",
        "backgroundImage": "./src/core/assets/icons/android-icon-background.png",
        "monochromeImage": "./src/core/assets/icons/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.kachielite.billbotfrontend",
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./src/core/assets/icons/favicon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.215586258976-j7of5i9df41ulqk1erks1ctr9pk8e2te"
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
