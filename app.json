{
  "expo": {
    "name": "BillBot",
    "slug": "billbot-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/BillBot-icon-light-1024.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/BillBot-splash-ios-light.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F9F5"
    },
    "ios": {
      "usesAppleSignIn": true,
      "supportsTablet": false,
      "bundleIdentifier": "com.kachielite.billbotfrontend",
      "buildNumber": "1",
      "icon": {
        "light": "./assets/BillBot-icon-light-1024.png",
        "dark": "./assets/BillBot-icon-dark-1024.png",
        "tinted": "./assets/BillBot-icon-tinted-1024.png"
      },
      "splash": {
        "image": "./assets/BillBot-splash-ios-light.png",
        "resizeMode": "contain",
        "backgroundColor": "#F4F9F5",
        "dark": {
          "image": "./assets/BillBot-splash-ios-dark.png",
          "resizeMode": "contain",
          "backgroundColor": "#0F1410"
        }
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "BillBot needs access to your photo library to attach receipts and payment proof.",
        "NSCameraUsageDescription": "BillBot needs camera access to capture receipts and payment proof.",
        "NSPhotoLibraryAddUsageDescription": "BillBot needs access to save images to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/BillBot-android-foreground.png",
        "backgroundImage": "./assets/BillBot-android-background-light.png",
        "monochromeImage": "./assets/BillBot-android-monochrome.png",
        "dark": {
          "foregroundImage": "./assets/BillBot-android-foreground.png",
          "backgroundImage": "./assets/BillBot-android-background-dark.png"
        }
      },
      "splash": {
        "image": "./assets/BillBot-android-foreground.png",
        "resizeMode": "contain",
        "backgroundColor": "#F4F9F5",
        "dark": {
          "image": "./assets/BillBot-android-foreground.png",
          "resizeMode": "contain",
          "backgroundColor": "#0F1410"
        }
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.kachielite.billbotfrontend",
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./src/core/assets/icons/favicon.png"
    },
    "plugins": [
      "expo-splash-screen",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.215586258976-j7of5i9df41ulqk1erks1ctr9pk8e2te"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "59233ac6-46d6-4cad-8fc0-edc4616cbaaa"
      }
    },
    "owner": "kachielite"
  }
}
