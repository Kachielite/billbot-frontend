{
  "expo": {
    "name": "billbot-frontend",
    "slug": "billbot-frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/core/assets/icons/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/core/assets/icons/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kachielite.billbotfrontend"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./src/core/assets/icons/android-icon-foreground.png",
        "backgroundImage": "./src/core/assets/icons/android-icon-background.png",
        "monochromeImage": "./src/core/assets/icons/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.kachielite.billbotfrontend"
    },
    "web": {
      "favicon": "./src/core/assets/icons/favicon.png"
    }
  }
}
